# ── Virtual Environment ────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Environment Variables (NEVER commit these) ─────────────────────────────
.env
.env.local
.env.production

# ── Gmail OAuth Tokens (NEVER commit these) ────────────────────────────────
token.json
credentials.json

# ── Python Cache ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Database Files ─────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Screenshots (generated at runtime) ────────────────────────────────────
screenshots/

# ── Attachment Downloads (generated at runtime) ────────────────────────────
/tmp/
quishguard_attachments/

# ── Pytest & Coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Alembic (keep versions folder, ignore auto-generated env) ──────────────
alembic/versions/*.py

# ── Build & Distribution ───────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── IDE & Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ── OS Files ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ── Playwright ─────────────────────────────────────────────────────────────
playwright-report/
test-results/